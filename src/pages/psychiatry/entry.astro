---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Psychiatry — Entry Requirements" description="RANZCP psychiatry training entry requirements and selection criteria.">
  <div class="page-header">
    <h1>Entry Requirements</h1>
    <p>Psychiatry — RANZCP</p>
  </div>
  <div class="section">
    <h2>Eligibility Criteria</h2>
    <ul class="item-list">
      <li>Medical degree — certified copies of academic record required. Australian graduates completing after 2023 must hold the NFPMT Certificate of Completion.</li>
      <li>Minimum <strong>24 months (2 years FTE)</strong> general hospital training after medical degree (for those commencing rotations from 2025)</li>
      <li>Current medical registration in Australia or Aotearoa New Zealand <span class="tag">NZ: general registration without endorsement</span></li>
      <li>Job offer in an accredited training post</li>
    </ul>
  </div>
  <div class="section">
    <h2>Application Documents</h2>
    <ul class="item-list">
      <li>Current CV with medical experience details</li>
      <li>Full academic records and certified university degree copy</li>
      <li>Medical registration certificate (dated within 3 months)</li>
      <li>Written statement (~300 words) explaining motivation for psychiatry</li>
      <li>Contact information for 3 referees + work performance statements from employers in past 24 months</li>
    </ul>
  </div>
  <div class="section">
    <h2>Selection Criteria & Weighting</h2>
    <table class="level-table">
      <thead><tr><th>Criterion</th><th>Weight</th></tr></thead>
      <tbody>
        <tr><td>Academic performance / CV</td><td>20%</td></tr>
        <tr><td>Interview performance</td><td>20%</td></tr>
        <tr><td>Referee reports</td><td>15%</td></tr>
        <tr><td>Psychiatry practice foundations</td><td>12%</td></tr>
        <tr><td>Teamwork ability</td><td>10%</td></tr>
        <tr><td>Communication skills</td><td>10%</td></tr>
        <tr><td>Psychiatric work experience</td><td>8%</td></tr>
        <tr><td>Diverse experiences</td><td>5%</td></tr>
      </tbody>
    </table>
    <p style="margin-top:1rem;">Selection is managed by local Branch Training Committees in each state/territory (AU) and New Zealand.</p>
  </div>
</Layout>
