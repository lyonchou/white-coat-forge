---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Psychiatry Training" description="RANZCP psychiatry fellowship training program overview.">
  <div class="page-header">
    <h1>Psychiatry Training</h1>
    <p>RANZCP — Royal Australian & New Zealand College of Psychiatrists · Fellowship Training Program</p>
  </div>
  <div class="stat-grid">
    <div class="stat"><div class="stat-number">60</div><div class="stat-label">months FTE minimum training</div></div>
    <div class="stat"><div class="stat-number">24</div><div class="stat-label">months pre-training hospital experience required</div></div>
    <div class="stat"><div class="stat-number">3</div><div class="stat-label">training stages</div></div>
  </div>
  <div class="section">
    <h2>Training Stages</h2>
    <div class="card"><div class="card-title">Stage 1</div><p>Foundation psychiatry training — core rotations across general adult, child/adolescent, and other settings.</p></div>
    <div class="card"><div class="card-title">Stage 2</div><p>Advanced training — building expertise and completing assessments including the psychotherapy written case and scholarly project.</p></div>
    <div class="card"><div class="card-title">Stage 3</div><p>Transition to independent practice. Optional advanced training certificates in subspecialties.</p></div>
  </div>
  <div class="section">
    <h2>Advanced Training Certificates</h2>
    <ul class="item-list">
      <li>Addiction Psychiatry</li>
      <li>Adult Psychiatry</li>
      <li>Child & Adolescent Psychiatry</li>
      <li>Consultation-Liaison Psychiatry</li>
      <li>Forensic Psychiatry</li>
      <li>Psychiatry of Old Age</li>
    </ul>
  </div>
  <div class="section">
    <h2>Quick Links</h2>
    <ul class="item-list">
      <li><a href="/psychiatry/entry">Entry requirements & selection criteria</a></li>
      <li><a href="/psychiatry/program">Program requirements & assessments</a></li>
    </ul>
  </div>
</Layout>
