---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="General Practice Training" description="RACGP AGPT general practice training program overview.">
  <div class="page-header">
    <h1>General Practice Training</h1>
    <p>RACGP — Australian General Practice Training (AGPT) Program · Commonwealth-funded</p>
  </div>
  <div class="stat-grid">
    <div class="stat"><div class="stat-number">3–4</div><div class="stat-label">years full-time training</div></div>
    <div class="stat"><div class="stat-number">3</div><div class="stat-label">FRACGP examinations</div></div>
    <div class="stat"><div class="stat-number">2027</div><div class="stat-label">intake — applications close 14 Apr 2026</div></div>
  </div>
  <div class="section">
    <h2>Program Features</h2>
    <ul class="item-list">
      <li>Commonwealth-funded training across Australia</li>
      <li>Flexible part-time options available alongside full-time</li>
      <li>Recognition of prior learning available</li>
      <li>Rural Generalist Fellowship pathway available</li>
      <li>Training locations across multiple regions and states/territories</li>
    </ul>
  </div>
  <div class="section">
    <h2>Quick Links</h2>
    <ul class="item-list">
      <li><a href="/gp/entry">Entry requirements & application</a></li>
      <li><a href="/gp/exams">FRACGP Examinations — AKT, KFP, CCE</a></li>
    </ul>
  </div>
</Layout>
