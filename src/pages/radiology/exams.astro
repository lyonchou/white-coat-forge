---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Radiology — Examinations" description="RANZCR clinical radiology Phase 1 and Phase 2 examination structure.">
  <div class="page-header">
    <h1>Examinations</h1>
    <p>Clinical Radiology — RANZCR</p>
  </div>
  <div class="section">
    <h2>Phase 1 Examinations</h2>
    <p>Two separate written examinations. Both must be passed to progress to Phase 2.</p>
    <div class="card"><div class="card-title">Anatomy</div><p>Written examination covering radiological anatomy.</p></div>
    <div class="card"><div class="card-title">Applied Imaging Technology</div><p>Written examination covering physics and technology of medical imaging.</p></div>
  </div>
  <div class="section">
    <h2>Phase 2 Examinations</h2>
    <p>Requires minimum <strong>24 months FTE</strong> of accredited training before sitting the written examination.</p>
    <div class="card">
      <div class="card-title">MCQ Examination</div>
      <p>Multiple-choice question exam covering broad radiology knowledge.</p>
    </div>
    <div class="card">
      <div class="card-title">Case Reporting Examination</div>
      <p>Written reporting of clinical imaging cases — tests systematic approach and reporting skills.</p>
    </div>
    <div class="card">
      <div class="card-title">OSCER — Objective Structured Clinical Examination in Radiology</div>
      <p>Structured clinical examination assessing practical radiology skills and patient interaction.</p>
    </div>
  </div>
  <div class="section">
    <h2>Phase 3 Progression</h2>
    <p>Minimum <strong>48 months FTE</strong> of accredited training (Phase 1 + Phase 2 combined) required before progressing to Phase 3.</p>
  </div>
</Layout>
