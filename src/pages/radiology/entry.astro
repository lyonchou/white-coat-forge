---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Radiology — Entry Requirements" description="RANZCR clinical radiology training entry requirements and application process.">
  <div class="page-header">
    <h1>Entry Requirements</h1>
    <p>Clinical Radiology — RANZCR</p>
  </div>
  <div class="section">
    <h2>Eligibility Criteria</h2>
    <ul class="item-list">
      <li>Graduate of a medical school recognised by the Medical Board of Australia and RANZCR Board</li>
      <li>OR successful completion of both Part I and Part II AMC examinations (overseas medical graduates) <span class="tag">AU</span></li>
      <li>Overseas trained doctors eligible if meeting general eligibility criteria</li>
      <li>Applications capped at <strong>4 non-consecutive attempts</strong></li>
    </ul>
    <div class="card">
      <div class="card-title">Application Attempts</div>
      <p>Applying for multiple positions/jurisdictions in the same calendar year counts as one attempt. Maximum 4 attempts total, non-consecutive.</p>
    </div>
  </div>
</Layout>
