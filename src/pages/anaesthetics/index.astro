---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Anaesthetics Training" description="ANZCA Anaesthesia Training Program overview — entry, structure, assessments, and fellowship.">
  <div class="page-header">
    <h1>Anaesthetics Training</h1>
    <p>ANZCA Anaesthesia Training Program — the only accredited anaesthesia training program in Australia and Aotearoa New Zealand.</p>
  </div>

  <div class="stat-grid">
    <div class="stat">
      <div class="stat-number">5+</div>
      <div class="stat-label">years minimum supervised clinical training</div>
    </div>
    <div class="stat">
      <div class="stat-number">104</div>
      <div class="stat-label">weeks general hospital experience required to apply</div>
    </div>
    <div class="stat">
      <div class="stat-number">158</div>
      <div class="stat-label">accredited training sites across AU & NZ</div>
    </div>
    <div class="stat">
      <div class="stat-number">7</div>
      <div class="stat-label">professional competency roles</div>
    </div>
  </div>

  <div class="section">
    <h2>Training Phases</h2>
    <div class="card">
      <div class="card-title">Introductory Training (IT)</div>
      <p>26 weeks. MCQ, Specified Emergency Scenarios, and workplace-based assessments. Level 1 supervision until requirements met.</p>
    </div>
    <div class="card">
      <div class="card-title">Basic Training</div>
      <p>~2 years. Fundamental competency development. Primary Exam (PEx) completed during this phase.</p>
    </div>
    <div class="card">
      <div class="card-title">Advanced Training</div>
      <p>~2 years. Specialised Study Units (SSUs). Final Exam (FEx) + Patient Clinical Interaction Assessment (PCIA) before progressing.</p>
    </div>
    <div class="card">
      <div class="card-title">Provisional Fellowship (PF)</div>
      <p>Final year. Transition toward independent practice. Clinical leadership and teaching development.</p>
    </div>
  </div>

  <div class="section">
    <h2>Quick Links</h2>
    <ul class="item-list">
      <li><a href="/anaesthetics/entry">Entry requirements & application process</a></li>
      <li><a href="/anaesthetics/program">Assessment & program requirements</a></li>
      <li><a href="/anaesthetics/curriculum">Curriculum — Roles in Practice, Clinical Fundamentals, SSUs</a></li>
      <li><a href="/anaesthetics/exams">Examinations — PEx and FEx</a></li>
    </ul>
  </div>
</Layout>
