---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home">
  <div class="page-header">
    <h1>Three paths.<br/>One forge.</h1>
    <p>
      Entry requirements, training programs, assessment standards, and progression criteria
      for RACP Physician, ANZCA Anaesthetics, and CICM Intensive Care training in Australia
      and Aotearoa New Zealand.
    </p>
  </div>

  <div class="section">
    <h2>Choose Your Path</h2>

    <div class="card">
      <div class="card-title">Physician / Paediatrician <span class="tag">RACP</span></div>
      <p>36-month FTE clinical training · 49 competencies · 3 phases · Written + Clinical Examinations</p>
      <p style="margin-top:0.75rem;">
        <a href="/entry">Entry</a> &nbsp;·&nbsp;
        <a href="/program">Program</a> &nbsp;·&nbsp;
        <a href="/curriculum">Curriculum</a> &nbsp;·&nbsp;
        <a href="/progression">Progression</a>
      </p>
    </div>

    <div class="card">
      <div class="card-title">Anaesthetics <span class="tag">ANZCA</span></div>
      <p>5+ years · 158 accredited sites · Primary Exam + Final Exam · 7 Roles in Practice</p>
      <p style="margin-top:0.75rem;">
        <a href="/anaesthetics/entry">Entry</a> &nbsp;·&nbsp;
        <a href="/anaesthetics/program">Program</a> &nbsp;·&nbsp;
        <a href="/anaesthetics/curriculum">Curriculum</a> &nbsp;·&nbsp;
        <a href="/anaesthetics/exams">Examinations</a>
      </p>
    </div>

    <div class="card">
      <div class="card-title">Intensive Care <span class="tag">CICM</span></div>
      <p>ICU training program information coming soon.</p>
      <p style="margin-top:0.75rem;"><a href="/icu">View ICU →</a></p>
    </div>
  </div>
</Layout>
