---
import Layout from '../layouts/Layout.astro';

const specialties = [
  { name: 'Physician / Paediatrician', tag: 'RACP', desc: '36-month FTE · 3 phases · Written + Clinical Exams', links: [{label:'Entry',href:'/entry'},{label:'Program',href:'/program'},{label:'Curriculum',href:'/curriculum'},{label:'Progression',href:'/progression'}] },
  { name: 'Anaesthetics', tag: 'ANZCA', desc: '5+ years · PEx + FEx · 7 Roles in Practice', links: [{label:'Entry',href:'/anaesthetics/entry'},{label:'Program',href:'/anaesthetics/program'},{label:'Curriculum',href:'/anaesthetics/curriculum'},{label:'Exams',href:'/anaesthetics/exams'}] },
  { name: 'Intensive Care', tag: 'CICM', desc: '6+ years · 42 months ICU · First + Second Part Exams', links: [{label:'Entry',href:'/icu/entry'},{label:'Program',href:'/icu/program'},{label:'Exams',href:'/icu/exams'}] },
  { name: 'Surgery', tag: 'RACS', desc: '5–6 years · 9 specialties · GSSE + Fellowship Exam', links: [{label:'Entry',href:'/surgery/entry'},{label:'Program',href:'/surgery/program'},{label:'Exams',href:'/surgery/exams'}] },
  { name: 'General Practice', tag: 'RACGP', desc: '3–4 years · Commonwealth-funded · AKT + KFP + CCE', links: [{label:'Entry',href:'/gp/entry'},{label:'Exams',href:'/gp/exams'}] },
  { name: 'Psychiatry', tag: 'RANZCP', desc: '5 years · 3 stages · EPAs + Written Case + Scholarly Project', links: [{label:'Entry',href:'/psychiatry/entry'},{label:'Program',href:'/psychiatry/program'}] },
  { name: 'Emergency Medicine', tag: 'ACEM', desc: '2–6 years · 3 pathways · MCQ Fellowship Exam', links: [{label:'Program',href:'/emergency/program'},{label:'Exams',href:'/emergency/exams'}] },
  { name: 'Dermatology', tag: 'ACD', desc: '4 years · Highly competitive · CBD + DCE + PDA assessments', links: [{label:'Entry',href:'/dermatology/entry'},{label:'Program',href:'/dermatology/program'}] },
  { name: 'Clinical Radiology', tag: 'RANZCR', desc: '5 years · 3 phases · Anatomy + Imaging Tech + MCQ + OSCER', links: [{label:'Entry',href:'/radiology/entry'},{label:'Exams',href:'/radiology/exams'}] },
];
---
<Layout title="Home">
  <div class="page-header">
    <h1>Nine paths.<br/>One forge.</h1>
    <p>
      Entry requirements, training programs, assessment standards, and progression criteria
      for Australian and Aotearoa New Zealand postgraduate medical training.
    </p>
  </div>

  <div class="section">
    <h2>Choose Your Path</h2>
    {specialties.map(s => (
      <div class="card">
        <div class="card-title">{s.name} <span class="tag">{s.tag}</span></div>
        <p>{s.desc}</p>
        <div class="card-links">
          {s.links.map(l => <a href={l.href}>{l.label}</a>)}
        </div>
      </div>
    ))}
  </div>
</Layout>
