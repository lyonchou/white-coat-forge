---
import Layout from '../layouts/Layout.astro';
---
<Layout title="ICU Training" description="CICM Intensive Care training program overview — entry, structure, assessments, and fellowship.">
  <div class="page-header">
    <h1>Intensive Care Training</h1>
    <p>CICM — College of Intensive Care Medicine of Australia and New Zealand.</p>
  </div>

  <div class="stat-grid">
    <div class="stat">
      <div class="stat-number">6+</div>
      <div class="stat-label">years minimum total training</div>
    </div>
    <div class="stat">
      <div class="stat-number">42</div>
      <div class="stat-label">months specific ICU training required</div>
    </div>
    <div class="stat">
      <div class="stat-number">100+</div>
      <div class="stat-label">accredited ICU sites across AU, NZ & beyond</div>
    </div>
    <div class="stat">
      <div class="stat-number">2</div>
      <div class="stat-label">intakes per year — March & August</div>
    </div>
  </div>

  <div class="section">
    <h2>Training Phases</h2>
    <div class="card">
      <div class="card-title">Phase 1 — Foundation Training</div>
      <p>6 months. Prerequisite. Includes required foundational ICU experience before formal trainee registration.</p>
    </div>
    <div class="card">
      <div class="card-title">Phase 2 — Core Training</div>
      <p>24 months of intensive care specific training. First Part Exam and Second Part Exam eligibility during this phase.</p>
    </div>
    <div class="card">
      <div class="card-title">Phase 3 — Transition Year</div>
      <p>12 months. Final phase. Preparation for independent specialist practice.</p>
    </div>
  </div>

  <div class="section">
    <h2>Quick Links</h2>
    <ul class="item-list">
      <li><a href="/icu/entry">Entry requirements & application process</a></li>
      <li><a href="/icu/program">Program requirements & assessments</a></li>
      <li><a href="/icu/exams">Examinations — First Part & Second Part</a></li>
    </ul>
  </div>
</Layout>
