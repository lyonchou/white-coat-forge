---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Surgery — Examinations" description="RACS SET Fellowship Examination structure and requirements.">
  <div class="page-header">
    <h1>Examinations</h1>
    <p>Surgery — RACS · Fellowship Examination</p>
  </div>
  <div class="section">
    <h2>Generic Surgical Sciences Exam (GSSE)</h2>
    <p>Pre-entry prerequisite. Written exam covering surgical sciences — anatomy, physiology, pathology, pharmacology.</p>
  </div>
  <div class="section">
    <h2>Fellowship Examination</h2>
    <p>Taken toward the end of SET training. Comprises <strong>7 segments total</strong>.</p>
    <div class="card">
      <div class="card-title">Standard Format (most specialties)</div>
      <p>2 written segments + 5 clinical/viva segments</p>
    </div>
    <div class="card">
      <div class="card-title">Vascular Surgery</div>
      <p>1 written segment + 6 clinical/viva segments</p>
    </div>
    <h3>Components</h3>
    <ul class="item-list">
      <li><strong>Written</strong> — MCQ and/or short answer questions covering surgical knowledge and judgment</li>
      <li><strong>Clinical/Viva</strong> — Structured oral examinations, clinical scenarios, and patient interactions</li>
    </ul>
  </div>
</Layout>
