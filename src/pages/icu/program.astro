---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="ICU — Program Requirements" description="CICM ICU training program and assessment requirements.">
  <div class="page-header">
    <h1>Program Requirements</h1>
    <p>Intensive Care — CICM</p>
  </div>

  <div class="section">
    <h2>Assessment Components</h2>
    <ul class="item-list">
      <li>First Part Examination (written + oral)</li>
      <li>Second Part Examination (written + oral)</li>
      <li>Workplace Competency Assessment</li>
      <li>Observed Clinical Encounter (OCE)</li>
      <li>In-Training Evaluation Report (ITER)</li>
      <li>Formal Projects</li>
      <li>30 Focused Cardiac Ultrasound Cases</li>
      <li>Second Part Paediatric Examination <span class="tag">paediatric pathway</span></li>
    </ul>
  </div>

  <div class="section">
    <h2>Observed Clinical Encounters (OCE)</h2>
    <div class="card">
      <div class="card-title">Format</div>
      <p>Clinical assessment (~20 min) + Presentation/discussion (~5–10 min) + Feedback (~5–10 min)</p>
    </div>
    <ul class="item-list">
      <li>Minimum <strong>1 OCE per 3 months</strong> of core training</li>
      <li>4 OCEs must reach "oversight or independent" level to be eligible for Second Part Exam</li>
      <li>Submitted via online assessment portal</li>
    </ul>
  </div>

  <div class="section">
    <h2>Formal Projects</h2>
    <ul class="item-list">
      <li>Must be presented before submission</li>
      <li>Submit: completed document + Supervisor's Project Evaluation Report + conflict-of-interest statement</li>
      <li>Review: 6–8 weeks by two independent reviewers from different states/territories</li>
    </ul>
    <div class="card">
      <div class="card-title">Felicity Hawker Medal</div>
      <p>Recognises outstanding project presentations at the Annual Scientific Meeting. Exempt from pre-presentation requirement.</p>
    </div>
  </div>

  <div class="section">
    <h2>Compulsory External Courses</h2>
    <p>Approved external course domains:</p>
    <ul class="item-list">
      <li>Advanced Airway Skills</li>
      <li>Communications (Clinical/Interpersonal)</li>
      <li>Introductory Echocardiography and Ultrasound</li>
      <li>Introductory Intensive Care Medicine (BASIC)</li>
      <li>Management Skills</li>
      <li>Donor Awareness</li>
      <li>ALS2 / APLS</li>
    </ul>
  </div>

  <div class="section">
    <h2>Financial Support</h2>
    <div class="card">
      <div class="card-title">Kanyini & Whanaungatanga Bursary</div>
      <p>$4,500 annually for Aboriginal, Torres Strait Islander, Māori, and Pasifika trainees. Covers training fees, examinations, courses, and related expenses.</p>
    </div>
  </div>
</Layout>
