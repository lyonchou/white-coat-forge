---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="ICU — Entry Requirements" description="CICM ICU training entry requirements, eligibility, and application process.">
  <div class="page-header">
    <h1>Entry Requirements</h1>
    <p>Intensive Care — CICM</p>
  </div>

  <div class="section">
    <h2>Application Intakes 2026</h2>
    <div class="card">
      <div class="card-title">Intake 1</div>
      <p>Applications open <strong>16 March</strong> — close <strong>30 March 2026</strong></p>
    </div>
    <div class="card">
      <div class="card-title">Intake 2</div>
      <p>Applications open <strong>17 August</strong> — close <strong>31 August 2026</strong></p>
    </div>
  </div>

  <div class="section">
    <h2>Mandatory Eligibility Criteria</h2>
    <ul class="item-list">
      <li>Primary medical degree obtained</li>
      <li>Completed 12-month internship (PGY1)</li>
      <li>Full General medical registration — AHPRA <span class="tag">AU</span>, MCNZ <span class="tag">NZ</span>, MCHK <span class="tag">HK</span>, or MCS <span class="tag">SG</span></li>
      <li><strong>6 months foundational ICU experience</strong> within the last 3 years — one 6-month term OR two 3-month terms</li>
      <li>Maximum 14 days leave per 3-month period (28 days per 6-month period)</li>
    </ul>
  </div>

  <div class="section">
    <h2>References Required</h2>
    <p>3 referees, all from the foundation training period:</p>
    <ul class="item-list">
      <li>1 × FCICM</li>
      <li>1 × FCICM who is a College Supervisor of Training (SOT) or unit Director</li>
      <li>1 × Senior ICU nurse with significant unit experience</li>
    </ul>
  </div>

  <div class="section">
    <h2>Required Rotations</h2>
    <p>Non-ICU rotations required across training phases:</p>
    <table class="level-table">
      <thead>
        <tr><th>Rotation</th><th>Duration</th><th>Timing</th></tr>
      </thead>
      <tbody>
        <tr><td>Clinical Anaesthesia</td><td>12 months</td><td>Phase 1 or 2</td></tr>
        <tr><td>Clinical Medicine</td><td>12 months</td><td>Phase 1 or 2</td></tr>
        <tr><td>Elective</td><td>6 months</td><td>Phase 1 or 2</td></tr>
        <tr><td>Rural exposure</td><td>6 months</td><td>PGY3+ (any phase)</td></tr>
        <tr><td>Paediatric exposure</td><td>3–6 months</td><td>Any phase</td></tr>
      </tbody>
    </table>
  </div>
</Layout>
