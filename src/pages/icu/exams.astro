---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="ICU — Examinations" description="CICM First Part and Second Part examination structure, requirements, and 2026 dates.">
  <div class="page-header">
    <h1>Examinations</h1>
    <p>Intensive Care — CICM · Both exams run twice yearly</p>
  </div>

  <div class="section">
    <h2>First Part Examination</h2>
    <p>Covers basic sciences in intensive care medicine. Syllabus: Fifth Edition (active from 2026.2 sitting).</p>

    <h3>Written Component (2 papers)</h3>
    <table class="level-table">
      <thead><tr><th>Section</th><th>Format</th><th>Duration</th></tr></thead>
      <tbody>
        <tr><td>SAQ</td><td>10 questions per paper</td><td>10 min each (~2.5 hrs/paper)</td></tr>
        <tr><td>MCQ</td><td>50 questions per paper</td><td>50 min per paper</td></tr>
      </tbody>
    </table>

    <h3>Oral Component</h3>
    <p>Cross-table vivas — 12-minute encounters with examiners.</p>

    <h3>Passing Requirements</h3>
    <ul class="item-list">
      <li>Achieve Angoff score in both SAQ and MCQ</li>
      <li>Borderline Regression score in oral</li>
      <li>Minimum 50% in oral</li>
    </ul>

    <h3>2026 Dates</h3>
    <table class="level-table">
      <thead><tr><th>Sitting</th><th>Applications</th><th>Written</th><th>Oral</th></tr></thead>
      <tbody>
        <tr><td>2026.1</td><td>6–20 Jan</td><td>25 Feb</td><td>29–30 Apr</td></tr>
        <tr><td>2026.2</td><td>9–23 Jun</td><td>5 Aug</td><td>14–15 Oct</td></tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <h2>Second Part Examination</h2>
    <p>Covers theory and practice of ICU, basic sciences, anaesthesia, and clinical medicine.</p>

    <h3>Eligibility</h3>
    <ul class="item-list">
      <li>12+ months Core ICU Training completed</li>
      <li>4 OCEs at oversight or independent level</li>
      <li>Maximum 5 total attempts</li>
    </ul>

    <h3>Written Component (2 papers)</h3>
    <table class="level-table">
      <thead><tr><th>Section</th><th>Format</th><th>Duration</th></tr></thead>
      <tbody>
        <tr><td>SAQ</td><td>15 questions per paper</td><td>~2.5 hrs per paper</td></tr>
      </tbody>
    </table>

    <h3>Oral Component</h3>
    <ul class="item-list">
      <li>"Hot cases" — 20-minute patient encounters</li>
      <li>Cross-table vivas — 12 minutes</li>
    </ul>

    <h3>Passing Requirements</h3>
    <ul class="item-list">
      <li>Achieve Angoff score on written</li>
      <li>Complete oral component</li>
    </ul>

    <h3>2026 Dates</h3>
    <table class="level-table">
      <thead><tr><th>Sitting</th><th>Written</th><th>Oral</th></tr></thead>
      <tbody>
        <tr><td>2026.1</td><td>11 Mar</td><td>18–22 May (Sydney) / 26 May optional (Canberra/Newcastle)</td></tr>
        <tr><td>2026.2</td><td>19 Aug</td><td>28–30 Oct (Melbourne) / 4 Nov optional (Adelaide)</td></tr>
      </tbody>
    </table>
  </div>

  <div class="section">
    <h2>Second Part Paediatric Examination</h2>
    <p>For trainees on the paediatric ICU pathway.</p>
    <ul class="item-list">
      <li>Eligibility: 12+ months Core Paediatric ICU Training + 4 OCEs</li>
      <li>Written: 15 SAQs per paper · 2.5 hrs per paper</li>
      <li>Oral: Hot cases + vivas</li>
      <li>Pass: 50% written minimum · ≥50% total · fail no more than one section</li>
      <li>Maximum 5 attempts</li>
    </ul>
    <h3>2026 Dates</h3>
    <table class="level-table">
      <thead><tr><th>Component</th><th>Date</th><th>Location</th></tr></thead>
      <tbody>
        <tr><td>Written</td><td>19 Aug 2026</td><td>Multiple venues</td></tr>
        <tr><td>Oral</td><td>12–13 Nov 2026</td><td>Melbourne</td></tr>
      </tbody>
    </table>
  </div>
</Layout>
