---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Emergency Medicine — Program Requirements" description="ACEM emergency medicine training program and assessment requirements.">
  <div class="page-header">
    <h1>Program Requirements</h1>
    <p>Emergency Medicine — ACEM · AEMTP (Pathway 3 example)</p>
  </div>
  <div class="section">
    <h2>Training Setting</h2>
    <ul class="item-list">
      <li>Training in emergency departments with at least 1 FTE Fellow of ACEM</li>
      <li>Full-time: 38 hrs/week · Part-time minimum: 0.5 FTE (19 hrs/week)</li>
      <li>30% of clinical time under direct ACEM Clinical Supervisor</li>
      <li>Primary Supervisor oversight required throughout</li>
    </ul>
  </div>
  <div class="section">
    <h2>Workplace-Based Assessments</h2>
    <p>Minimum requirements for AEMTP (Pathway 3):</p>
    <div class="stat-grid">
      <div class="stat"><div class="stat-number">3</div><div class="stat-label">Mini-CEX (Clinical Evaluation Exercises)</div></div>
      <div class="stat"><div class="stat-number">3</div><div class="stat-label">DOPS (Direct Observation of Procedural Skills)</div></div>
      <div class="stat"><div class="stat-number">1</div><div class="stat-label">DOCS (Communication Skills)</div></div>
      <div class="stat"><div class="stat-number">1</div><div class="stat-label">Procedural Checklist</div></div>
      <div class="stat"><div class="stat-number">2</div><div class="stat-label">Clinical Lead Shift Reports</div></div>
      <div class="stat"><div class="stat-number">1</div><div class="stat-label">Quality Improvement Activity</div></div>
    </div>
    <p style="font-size:0.875rem; color:var(--muted);">Assessment requirements vary by pathway. Pathway 1 and 2 have additional requirements.</p>
  </div>
</Layout>
