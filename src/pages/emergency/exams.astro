---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Emergency Medicine — Examinations" description="ACEM Fellowship examination structure, format, and 2026 dates.">
  <div class="page-header">
    <h1>Fellowship Examination</h1>
    <p>Emergency Medicine — ACEM · Twice yearly</p>
  </div>
  <div class="section">
    <h2>Format</h2>
    <div class="card">
      <div class="card-title">Online MCQ Examination</div>
      <p>50 multiple-choice questions · 60 minutes · Based on the ACEM curriculum</p>
    </div>
  </div>
  <div class="section">
    <h2>2026 Exam Dates</h2>
    <table class="level-table">
      <thead><tr><th>Sitting</th><th>Date</th></tr></thead>
      <tbody>
        <tr><td>2026.1</td><td>15 May 2026</td></tr>
        <tr><td>2026.2</td><td>13 November 2026</td></tr>
      </tbody>
    </table>
  </div>
</Layout>
