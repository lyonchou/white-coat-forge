---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Emergency Medicine Training" description="ACEM Advanced Emergency Medicine Training Program overview.">
  <div class="page-header">
    <h1>Emergency Medicine Training</h1>
    <p>ACEM — Australasian College for Emergency Medicine · Advanced Emergency Medicine Training Program (AEMTP)</p>
  </div>
  <div class="stat-grid">
    <div class="stat"><div class="stat-number">3</div><div class="stat-label">entry pathways depending on prior qualifications</div></div>
    <div class="stat"><div class="stat-number">2–6</div><div class="stat-label">years total depending on pathway</div></div>
    <div class="stat"><div class="stat-number">50</div><div class="stat-label">MCQ questions in Fellowship exam</div></div>
  </div>
  <div class="section">
    <h2>Training Pathways</h2>
    <div class="card">
      <div class="card-title">Pathway 1 — Standard</div>
      <p>PGY3+ with general registration. Requires FEMTP + IEMTP + AEMTP. ~6 years total, 18 months ED training.</p>
    </div>
    <div class="card">
      <div class="card-title">Pathway 2 — Prior Qualifications</div>
      <p>RACGP/ACRRM Fellow or 2+ years FTE ED experience. Requires IEMTP + AEMTP. ~4 years, 12 months ED training.</p>
    </div>
    <div class="card">
      <div class="card-title">Pathway 3 — Advanced Rural</div>
      <p>IEMTP completion or equivalent ED experience + advanced rural qualifications. AEMTP only. ~2 years, 6 months ED training.</p>
    </div>
  </div>
  <div class="section">
    <h2>Quick Links</h2>
    <ul class="item-list">
      <li><a href="/emergency/program">Program requirements & assessments</a></li>
      <li><a href="/emergency/exams">Fellowship Examination</a></li>
    </ul>
  </div>
</Layout>
